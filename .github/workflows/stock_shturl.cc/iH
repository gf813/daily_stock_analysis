name: 每日股市分析

on:
  workflow_dispatch:
  schedule:
    - cron: "0 10 * * 1-5"

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: 拉取代码
        uses: actions/checkout@v4

      - name: 设置Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: 安装依赖
        run: |
          python -m pip install --upgrade pip
          pip install akshare openai python-dotenv

      - name: 运行分析
        env:
          STOCK_LIST: ${{ shturl.cc/DoJqT1Bz }}
          OPENROUTER_API_KEY: ${{ shturl.cc/wh91Xw9SYydJ11uk }}
          WECHAT_WEBHOOK_URL: ${{ shturl.cc/bOGviLGOSgpIlENU }}
          AI_BASE_URL: "shturl.cc/mJeKoCcmLWbahNEL8W"
          AI_MODEL: "deepseek/deepseek-chat-v1"
        run: python shturl.

      - name: 完成
        run: echo "分析完成"
